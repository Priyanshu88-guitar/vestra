# ═══════════════════════════════════════════════════════
# VESTRA – Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════

# ─── SERVER ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MONGODB ──────────────────────────────────────────
# Local MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/vestra_db

# MongoDB Atlas (cloud) — uncomment and replace with your URI:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vestra_db?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────
# Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex').then?console.log(require('crypto').randomBytes(64).toString('hex')):0"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_use_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────
# Your frontend URL (for production)
FRONTEND_URL=http://localhost:5500

# ─── OPTIONAL: Serve frontend from same server ────────
SERVE_FRONTEND=false
